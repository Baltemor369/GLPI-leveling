# ════════════════════════════════════════════════════════════════════════════
#  GlpiLeveling — Configuration
#  Copier ce fichier en .env et remplir toutes les valeurs AVANT de lancer
#  docker compose up
# ════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Mot de passe de la base de données (choisir un mot de passe fort)
POSTGRES_PASSWORD=changez_moi

# URL de connexion — ne modifier que si vous utilisez une DB externe à Docker
DATABASE_URL=postgresql://glpi:changez_moi@db:5432/glpileveling

# ── GLPI ──────────────────────────────────────────────────────────────────────
# URL de l'API REST de votre instance GLPI (doit se terminer par /api.php)
GLPI_API_BASE_URL=https://votre-glpi.entreprise.com/api.php

# Client OAuth2 — à créer dans GLPI > Configuration > OAuth 2.0 > Ajouter un client
GLPI_OAUTH_CLIENT_ID=
GLPI_OAUTH_CLIENT_SECRET=

# Compte bot dédié dans GLPI (technicien avec droit lecture/écriture sur les tickets)
GLPI_BOT_USERNAME=bot-glpileveling
GLPI_BOT_PASSWORD=

# ── Synchronisation ───────────────────────────────────────────────────────────
# Intervalle en secondes entre chaque vérification des tickets fermés
SYNC_INTERVAL_SECONDS=60

# ── Ollama (LLM) ──────────────────────────────────────────────────────────────
# En Docker Compose (défaut) : http://ollama:11434
# Ollama sur une VM / serveur externe : http://192.168.x.x:11434
OLLAMA_API_URL=http://ollama:11434

# Modèle à utiliser — mistral recommandé (bon équilibre qualité/performance)
OLLAMA_MODEL=mistral

# ── Application ───────────────────────────────────────────────────────────────
# Port exposé sur le serveur hôte (accès via http://serveur:8501)
APP_PORT=8501

# Fuseau horaire du serveur — utilisé pour l'affichage des heures dans l'app
TZ=Europe/Paris
